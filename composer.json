{
    "name": "mattyeend/dynamic-enum-generator",
    "description": "Automatically generate PHP enums from database columns in Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "Laravel",
        "Dynamic",
        "Generate",
        "Enums",
        "Enum",
        "Dynamic-Enum",
        "Dynamic-Enums",
        "Generate-Enum",
        "Generate-Enums",
        "Dynamic-Enum-Generator",
        "Package"
    ],
    "authors": [
        {
            "name": "Matt Yeend",
            "email": "mail@mattyeend.co.uk"
        }
    ],
    "autoload": {
        "psr-4": {
            "MattYeend\\DynamicEnumGenerator\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MattYeend\\DynamicEnumGenerator\\DynamicEnumServiceProvider"
            ]
        }
    },
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    }
}
